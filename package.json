{
  "name": "study-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"node scripts/cors-proxy.js\" \"vite\" --names \"PROXY,VITE\" --prefix \"[{name}]\" --kill-others-on-fail",
    "dev:tauri": "vite",
    "cors-proxy": "node scripts/cors-proxy.js",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\"",
    "typecheck": "tsc -b --noEmit",
    "preview": "vite preview",
    "tauri": "tauri",
    "buildandroid": "npm run build && npx cap sync android",
    "buildios": "npm run build && npx cap sync ios",
    "buildandios": "npm run build && npx cap sync android && npx cap sync ios",
    "open:android": "npx cap open android",
    "open:ios": "npx cap open ios",
    "buildapk": "npm run buildandroid && npx cap open android"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.41",
    "@ai-sdk/openai-compatible": "^2.0.35",
    "@capacitor/android": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-http": "^2.5.7",
    "@types/katex": "^0.16.8",
    "@types/react-syntax-highlighter": "^15.5.13",
    "ai": "^6.0.116",
    "capacitor-edge-to-edge": "^2.1.1",
    "dexie": "^4.3.0",
    "katex": "^0.16.35",
    "lucide-react": "^0.577.0",
    "mathlive": "^0.108.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.1",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "solid-js": "^1.9.11",
    "vite-plugin-solid": "^2.11.10"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.2.0",
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.2.1",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^8.0.0-beta.13"
  },
  "overrides": {
    "vite": "^8.0.0-beta.13"
  }
}
